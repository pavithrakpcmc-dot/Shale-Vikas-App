rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isOwner(uid) { return signedIn() && request.auth.uid == uid; }

    match /users/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /needs/{needId} {
      allow read: if true;
      allow create: if signedIn();
      allow update: if signedIn(); // headmasters or contributors via aggregation
      allow delete: if false;
    }

    match /pledges/{pledgeId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.alumniId == request.auth.uid;
      allow update, delete: if false;
    }

    match /leaderboard/{uid} {
      allow read: if true;
      allow write: if false; // Only Cloud Functions should update this
    }
    
    // Support for school settings or metadata if needed
    match /schools/{schoolId} {
      allow read: if true;
      allow write: if false;
    }
  }
}

